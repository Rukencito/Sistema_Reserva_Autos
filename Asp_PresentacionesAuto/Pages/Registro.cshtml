@* Pages/Registro.cshtml *@
@page
@model Asp_PresentacionesAuto.Pages.RegistroModel
@{
    ViewData["Title"] = "Registro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistema Autos - Registro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
    <style>
            :root {
                --paper: #f5f3ee;
                --cream: #ede9e0;
                --ink: #0c0c10;
                --rust: #c94c1e;
                --rust-dim: #a03a14;
            }

            body {
                background: var(--ink);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                font-family: 'DM Mono', monospace;
            }

            .registro-card {
                background: var(--paper);
                border: 2px solid var(--rust);
                border-radius: 4px;
                padding: 40px;
                width: 100%;
                max-width: 500px;
                color: var(--ink);
            }

                .registro-card h2 {
                    text-align: center;
                    margin-bottom: 4px;
                    font-family: 'Syne', sans-serif;
                    font-weight: 800;
                    font-size: 2rem;
                    color: var(--ink);
                }

                .registro-card p.subtitulo {
                    text-align: center;
                    color: var(--rust);
                    margin-bottom: 30px;
                    font-size: 0.8rem;
                    text-transform: uppercase;
                    letter-spacing: 0.1em;
                }

            .form-label {
                color: var(--ink);
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                font-weight: 600;
            }

            .form-control {
                background: var(--cream);
                border: 1px solid var(--ink);
                border-radius: 2px;
                color: var(--ink);
                font-family: 'DM Mono', monospace;
                padding: 10px 12px;
            }

                .form-control:focus {
                    background: var(--cream);
                    border-color: var(--rust);
                    color: var(--ink);
                    box-shadow: 0 0 0 2px rgba(201,76,30,0.2);
                }

                .form-control::placeholder {
                    color: rgba(12,12,16,0.35);
                }

            .btn-registrar {
                background: var(--rust);
                border: none;
                border-radius: 2px;
                padding: 11px;
                width: 100%;
                color: var(--paper);
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                margin-top: 10px;
                cursor: pointer;
            }

                .btn-registrar:hover {
                    background: var(--rust-dim);
                }

            .login-link {
                text-align: center;
                margin-top: 20px;
                color: rgba(12,12,16,0.55);
                font-size: 0.85rem;
            }

                .login-link a {
                    color: var(--rust);
                    text-decoration: none;
                }

                    .login-link a:hover {
                        text-decoration: underline;
                    }

            .error-msg {
                background: rgba(201,76,30,0.1);
                border: 1px solid var(--rust);
                border-radius: 2px;
                padding: 10px 14px;
                text-align: center;
                margin-bottom: 15px;
                font-size: 0.85rem;
                color: var(--rust);
            }

            .exito-msg {
                background: rgba(40,167,69,0.1);
                border: 1px solid #28a745;
                border-radius: 2px;
                padding: 10px 14px;
                text-align: center;
                margin-bottom: 15px;
                font-size: 0.85rem;
                color: #1a6b30;
            }
    </style>
</head>
<body>
    <div class="registro-card">
        <h2>🚗 Sistema Autos</h2>
        <p class="subtitulo">Creá tu cuenta</p>

        <form method="POST" asp-page-handler="BtRegistrar">
            @Html.AntiForgeryToken()

            @if (!string.IsNullOrEmpty(Model.MensajeError))
            {
                <div class="error-msg">@Model.MensajeError</div>
            }

            @if (!string.IsNullOrEmpty(Model.MensajeExito))
            {
                <div class="exito-msg">@Model.MensajeExito</div>
            }

            <div class="row">
                <div class="col-6 mb-3">
                    <label class="form-label">Nombre *</label>
                    <input class="form-control" asp-for="Nombre" placeholder="Miguel" />
                </div>
                <div class="col-6 mb-3">
                    <label class="form-label">Apellido</label>
                    <input class="form-control" asp-for="Apellido" placeholder="Bustamante" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Teléfono</label>
                <input class="form-control" asp-for="Telefono" placeholder="3189765423" />
            </div>

            <div class="mb-3">
                <label class="form-label">Correo *</label>
                <input type="email" class="form-control" asp-for="Correo" placeholder="Usuario@Correo.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña *</label>
                <input type="password" class="form-control" asp-for="Contrasena" placeholder="••••••••" />
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmar Contraseña *</label>
                <input type="password" class="form-control" asp-for="ConfirmarContrasena" placeholder="••••••••" />
            </div>

            <button type="submit" class="btn-registrar">Crear cuenta</button>
        </form>

        <div class="login-link">
            ¿Ya tenés cuenta? <a asp-page="/Login">Iniciá sesión</a>
        </div>
    </div>
</body>
</html>