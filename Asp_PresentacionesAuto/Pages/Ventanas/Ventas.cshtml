@page
@using Ventas_Razor.Pages
@model VentasHTMLModel
@{
    ViewData["Title"] = "Ventas";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Ventas</h3>
            </div>
            
            <div>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Venta!= null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Venta == null)" />
            </div>

            @if (Model.Venta != null)
            {
                <input type="hidden"
                       asp-for="@Model.Venta!.Id" />

                <div>
                    <div class="form-group">
                        <label>Fecha de Venta</label>
                        <div class="col-6">
                            <input id="inFechaVenta"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Venta.FechaVenta" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Precio de Venta</label>
                        <div class="col-6">
                            <input id="inPrecioVenta"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Venta!.PrecioVenta" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Tipo de Pago</label>
                        <div class="col-6">
                            <input id="inTipoPago"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Venta!.TipoPago" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Estado de Pago</label>
                        <div class="col-6">
                            <input id="inEstadoPago"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Venta!.EstadoPago" />
                        </div>
                    </div>
                </div>
                
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Venta != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">Desea borrar el Venta?</h6>
                            <h6 align="left">@Model.Venta!.PrecioVenta</h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>FechaVenta</th>
                        <th>PrecioVenta</th>
                        <th>TipoPago</th>
                        <th>EstadoPago</th>
                    </tr>
                
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.FechaVenta</td>
                            <td>@elemento.PrecioVenta</td>
                            <td>@elemento.TipoPago</td>
                            <td>@elemento.EstadoPago</td>
                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>