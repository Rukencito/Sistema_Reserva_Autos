@*Pages/Ventanas/Admin/Autos_Razor.cshtml*@
@page
@model Asp_PresentacionesAuto.Pages.Ventanas.Admin.AutosHTMLModel;
@{
    ViewData["Title"] = "Autos";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Autos</h3>
            </div>
            
            <div>
                <a href="/Ventanas/Admin/IndexAdmin"
                class="btn btn-danger">&#8592; Regresar</a>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Auto!= null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Auto == null)" />
            </div>

            @if (Model.Auto != null)
            {
                <input type="hidden"
                       asp-for="@Model.Auto!.Id" />

                <div>
                    <div class="form-group">
                        <label>Placa</label>
                        <div class="col-6">
                            <input id="inPlaca"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Auto!.Placa" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Marca</label>
                        <div class="col-6">
                            <input id="inMarca"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Auto!.Marca" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Año</label>
                        <div class="col-6">
                            <input id="inAño"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Auto!.Año" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Modelo</label>
                    <div class="col-6">
                        <input id="inModelo"
                               class="cts_forms form-control"
                               asp-for="@Model.Auto!.Modelo" />
                    </div>
                </div>
                <div class="form-group">
                    <label>EstadoAuto</label>
                    <input type="checkbox" asp-for="@Model.Auto!.Estado" />
                </div>
                <div class="form-group">
                    <label>Parqueadero</label>
                    <div class="col-6">
                        <select id="Parqueaderos"
                                class="cts_forms form-control"
                                asp-for="@Model.Auto!.Parqueaderos"
                                asp-items="@(new SelectList(Model.ObtenerParqueaderos(), "Id", "Nombre"))">
                            <option value="">Seleccione un Parqueadero</option>
                        </select>
                    </div>
                </div>
                     <div class="form-group">
                        <label>Dueño</label>
                        <div class="col-6">
                            <select id="Duenos"
                                    class="cts_forms form-control"
                                    asp-for="@Model.Auto!.Duenos"
                                    asp-items="@(new SelectList(Model.ObtenerDuenos(), "Id", "Nombre"))">
                                <option value="">Seleccione un Dueño</option>
                            </select>
                        </div>
                    </div>
                <div class="form-group">
                    <label>Sucursal</label>
                    <div class="col-6">
                        <select id="Sucursales"
                                class="cts_forms form-control"
                                asp-for="@Model.Auto!.Sucursales"
                                asp-items="@(new SelectList(Model.ObtenerSucursales(), "Id", "Nombre"))">
                            <option value="">Seleccione una Sucursal</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Inventario</label>
                    <div class="col-6">
                        <select id="Inventarios"
                                class="cts_forms form-control"
                                asp-for="@Model.Auto!.Inventarios"
                                asp-items="@(new SelectList(Model.ObtenerInventarios(), "Id", "Cantidad"))">
                            <option value="">Seleccione un Inventario</option>
                        </select>
                    </div>
                </div>
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("/Pages/Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Auto != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">Desea borrar el Auto?</h6>
                            <h6 align="left">@Model.Auto!.Placa</h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Placa</th>
                        <th>Marca</th>
                        <th>Año</th>
                        <th>Modelo</th>
                        <th>Estado</th>
                        <th>Parqueadero</th>
                        <th>Dueños</th>
                        <th>Sucursal</th>
                        <th>Inventario</th>
                    </tr>
                
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Placa</td>
                            <td>@elemento.Marca</td>
                            <td>@elemento.Año</td>
                            <td>@elemento.Modelo</td>
                            <td>@elemento.Estado</td>
                            <td>@elemento.Parqueadero</td>
                            <td>@elemento.Dueno</td>
                            <td>@elemento.Sucursal</td>
                            <td>@elemento.Inventario</td>


                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>