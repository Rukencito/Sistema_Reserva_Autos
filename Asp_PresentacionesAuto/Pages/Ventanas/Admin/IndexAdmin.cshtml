                    </a>
                </li>
                <li class="adm-item cat-ops">
                    <a asp-page="/Ventanas/Admin/Reservas">
                        <span class="adm-item-icon">📅</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Reservas</span>
                            <span class="adm-item-desc">Reservas de clientes</span>
