                    </a>
                </li>
                <li class="adm-item cat-ppl">
                    <a asp-page="/Ventanas/Admin/DuenosHTML">
                        <span class="adm-item-icon">🤵</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Dueños</span>
                            <span class="adm-item-desc">Propietarios de vehículos</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
            </ul>

        </div>

        <!-- COL 2 — AUTOS E INFRAESTRUCTURA -->
