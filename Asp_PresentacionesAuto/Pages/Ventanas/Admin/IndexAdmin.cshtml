@*Pages/Ventanas/Admin/IndexAdmin_Razor.cshtml*@
@page
@model Asp_PresentacionesAuto.Pages.Ventanas.Admin.IndexAdminModel;
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Panel Administrador";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap');

    :root {
        --ink:       #0c0c10;
        --paper:     #f5f3ee;
        --cream:     #ede9e0;
        --rust:      #c94c1e;
        --rust-dim:  #a03a14;
        --gold:      #c8922a;
        --slate:     #3a3a4a;
        --mist:      #9898a8;
        --line:      #d8d4cc;
        --col-cfg:   #1e1e2e;
        --col-ppl:   #1a2e1a;
        --col-car:   #2e1a0e;
        --col-ops:   #0e1e2e;
        --col-fin:   #2e240e;
    }

    /* Reset para esta página */
    .admin-root {
        background: var(--paper);
        color: var(--ink);
        font-family: 'DM Mono', monospace;
        min-height: 100vh;
        padding: 0;
    }

    /* ── ENCABEZADO ── */
    .adm-masthead {
        padding: 3rem 3rem 2rem;
        border-bottom: 2px solid var(--ink);
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 2rem;
    }

    .adm-masthead-left h1 {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.4rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1;
        color: var(--ink);
        margin: 0;
    }

    .adm-masthead-left h1 em {
        font-style: normal;
        color: var(--rust);
    }

    .adm-masthead-left p {
        margin: 0.5rem 0 0;
        font-size: 0.72rem;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: var(--mist);
    }

    .adm-badge {
        background: var(--ink);
        color: var(--paper);
        padding: 0.4rem 1rem;
        border-radius: 2px;
        font-size: 0.7rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        white-space: nowrap;
    }

    /* ── LAYOUT COLUMNAS ── */
    .adm-body {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 0;
    }

    /* ── COLUMNA ── */
    .adm-col {
        border-right: 1px solid var(--line);
        padding: 0;
    }

    .adm-col:last-child {
        border-right: none;
    }

    /* ── ENCABEZADO DE SECCIÓN ── */
    .sec-head {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.4rem 2rem 1.2rem;
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        background: var(--paper);
        z-index: 2;
    }

    .sec-num {
        font-family: 'Syne', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--mist);
        letter-spacing: 2px;
    }

    .sec-title {
        font-family: 'Syne', sans-serif;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--slate);
    }

    .sec-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        margin-left: auto;
        flex-shrink: 0;
    }

    /* colores de dot por sección */
    .dot-cfg  { background: #7c7cff; }
    .dot-ppl  { background: #4caf50; }
    .dot-car  { background: var(--rust); }
    .dot-ops  { background: #00bcd4; }
    .dot-fin  { background: var(--gold); }

    /* ── LISTA DE ITEMS ── */
    .adm-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .adm-item a {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 2rem;
        text-decoration: none;
        color: var(--slate);
        border-bottom: 1px solid var(--line);
        transition: background 0.15s, color 0.15s, padding-left 0.2s;
        position: relative;
    }

    .adm-item a::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--item-accent, var(--rust));
        transform: scaleY(0);
        transition: transform 0.2s;
        transform-origin: bottom;
    }

    .adm-item a:hover {
        background: var(--cream);
        color: var(--ink);
        padding-left: 2.4rem;
    }

    .adm-item a:hover::before {
        transform: scaleY(1);
    }

    .adm-item-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        opacity: 0.85;
    }

    .adm-item-text {
        flex: 1;
        min-width: 0;
    }

    .adm-item-name {
        font-size: 0.82rem;
        font-weight: 500;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .adm-item-desc {
        font-size: 0.65rem;
        color: var(--mist);
        display: block;
        margin-top: 0.15rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .adm-arrow {
        font-size: 0.7rem;
        color: var(--mist);
        transition: transform 0.2s, color 0.2s;
        flex-shrink: 0;
    }

    .adm-item a:hover .adm-arrow {
        transform: translateX(4px);
        color: var(--item-accent, var(--rust));
    }

    /* colores de acento por sección */
    .cat-cfg  { --item-accent: #7c7cff; }
    .cat-ppl  { --item-accent: #4caf50; }
    .cat-car  { --item-accent: var(--rust); }
    .cat-ops  { --item-accent: #00bcd4; }
    .cat-fin  { --item-accent: var(--gold); }

    /* ── SECCIÓN ANCHA (fila inferior) ── */
    .adm-wide {
        grid-column: 1 / -1;
        border-top: 2px solid var(--line);
        border-right: none;
    }

    .adm-wide .sec-head {
        border-bottom: 1px solid var(--line);
    }

    .adm-wide .adm-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    }

    .adm-wide .adm-item a {
        border-right: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
    }

    /* ── PIE ── */
    .adm-footer {
        border-top: 2px solid var(--ink);
        padding: 1.2rem 3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.65rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--mist);
    }

    /* ── Responsive ── */
    @@media (max-width: 900px) {
        .adm-body { grid-template-columns: 1fr; }
        .adm-col  { border-right: none; border-bottom: 1px solid var(--line); }
        .adm-wide { grid-column: 1; }
        .adm-masthead { flex-direction: column; align-items: flex-start; }
    }
</style>

<div class="admin-root">

    <!-- MASTHEAD -->
    <div class="adm-masthead">
        <div class="adm-masthead-left">
            <h1>Panel <em>Admin</em></h1>
