                <li class="adm-item cat-cfg">
                    <a asp-page="/Ventanas/Admin/Usuarios">
                        <span class="adm-item-icon">👤</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Usuarios</span>
                            <span class="adm-item-desc">Cuentas de acceso al sistema</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-cfg">
                    <a asp-page="/Ventanas/Admin/Roles">
                        <span class="adm-item-icon">🛡️</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Roles</span>
                            <span class="adm-item-desc">Tipos de perfil del sistema</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-cfg">
                    <a asp-page="/Ventanas/Admin/Permisos">
                        <span class="adm-item-icon">🔑</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Permisos</span>
                            <span class="adm-item-desc">Accesos por rol</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
            </ul>

            <div class="sec-head" style="margin-top:0.5rem;">
                <span class="sec-num">02</span>
                <span class="sec-title">Personas</span>
                <span class="sec-dot dot-ppl"></span>
            </div>
            <ul class="adm-list">
                <li class="adm-item cat-ppl">
                    <a asp-page="/Ventanas/Admin/ClientesHTML">
                        <span class="adm-item-icon">🙋</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Clientes</span>
                            <span class="adm-item-desc">Registro de clientes</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-ppl">
                    <a asp-page="/Ventanas/Admin/EmpleadosHTML">
                        <span class="adm-item-icon">👷</span>
