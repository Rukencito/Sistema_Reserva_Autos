                    </a>
                </li>
                <li class="adm-item cat-ops">
                    <a asp-page="/Ventanas/Admin/DevolucionesHTML">
                        <span class="adm-item-icon">↩️</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Devoluciones</span>
                            <span class="adm-item-desc">Retornos de vehículos</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-ops">
                    <a asp-page="/Ventanas/Admin/ContratosHTML ">
                        <span class="adm-item-icon">📝</span>
