                    </a>
                </li>
                <li class="adm-item cat-car">
                    <a asp-page="/Ventanas/Admin/GarantiasHTML">
                        <span class="adm-item-icon">🛡️</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Garantías</span>
