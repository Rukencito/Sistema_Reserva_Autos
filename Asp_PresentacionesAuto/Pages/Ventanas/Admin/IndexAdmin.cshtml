            </div>
            <ul class="adm-list">
                <li class="adm-item cat-car">
                    <a asp-page="/Ventanas/Admin/AutosHTML">
                        <span class="adm-item-icon">🚗</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Autos</span>
                            <span class="adm-item-desc">Flota de vehículos</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-car">
                    <a asp-page="/Ventanas/Admin/Parquederos">
                        <span class="adm-item-icon">🅿️</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Parqueaderos</span>
                            <span class="adm-item-desc">Espacios de estacionamiento</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-car">
                    <a asp-page="/Ventanas/Admin/Sucursales">
                        <span class="adm-item-icon">🏢</span>
                        <span class="adm-item-text">
                            <span class="adm-item-name">Sucursales</span>
                            <span class="adm-item-desc">Sedes de la empresa</span>
                        </span>
                        <span class="adm-arrow">→</span>
                    </a>
                </li>
                <li class="adm-item cat-car">
                    <a asp-page="/Ventanas/Admin/Talleres">
                        <span class="adm-item-icon">🔧</span>
                        <span class="adm-item-text">
