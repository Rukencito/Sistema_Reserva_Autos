@*Pages/Ventanas/Admin/Devoluciones_Razor.cshtml*@
@page
@model Asp_PresentacionesAuto.Pages.Ventanas.Admin.DevolucionesHTMLModel;
@{
    ViewData["Title"] = "Devoluciones";
    string urlRegresar;
    var rol = HttpContext.Session.GetString("RolId");

    if (rol == "2")
        urlRegresar = "/Ventanas/Cliente/IndexClientes";
    else if (rol == "3")
        urlRegresar = "/Ventanas/Empleado/IndexEmpleados";
    else if (rol == "4")
        urlRegresar = "/Ventanas/Dueno/IndexDuenos";
    else
        urlRegresar = "/Ventanas/Admin/IndexAdmin";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Devoluciones</h3>
            </div>
            
            <div>
                <a href="@urlRegresar" class="btn btn-danger">&#8592; Regresar</a>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Devolucion != null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Devolucion == null)" />
            </div>

            @if (Model.Devolucion != null)
            {
                <input type="hidden"
                       asp-for="@Model.Devolucion!.Id" />

                <div>
                    <div class="form-group">
                        <label>Fecha Entrega</label>
                        <div class="col-6">
                            <input id="inFechaEntrega"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Devolucion!.FechaEntrega" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>NivelCombustible</label>
                        <div class="col-6">
                            <input id="inNivelCombustible"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Devolucion!.NivelCombustible" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Observaciones</label>
                        <div class="col-6">
                            <input id="inObservaciones"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Devolucion!.Observaciones" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Alquiler</label>
                    <div class="col-6">
                        <select id="Alquileres"
                                class="cts_forms form-control"
                                asp-for="@Model.Devolucion!.Alquileres"
                                asp-items="@(new SelectList(Model.ObtenerAlquileres(), "Id", "FechaInicio"))">
                            <option value="">Seleccione un Alquiler</option>
                        </select>
                    </div>
                </div>
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("/Pages/Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Devolucion != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">Desea borrar el Devolucion?</h6>
                            <h6 align="left">@Model.Devolucion!.FechaEntrega</h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>FechaEntrega</th>
                        <th>NivelCombustible</th>
                        <th>Observaciones</th>
                        <th>Alquileres</th>
                    </tr>
                
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.FechaEntrega</td>
                            <td>@elemento.NivelCombustible</td>
                            <td>@elemento.Observaciones</td>
                            <td>@elemento.Alquiler?.FechaInicio.ToString("dd/MM/yyyy")</td>
                            
                            @{
                            var rol = HttpContext.Session.GetString("RolId");
                            }
                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>

                            @if (rol == "1" || rol == "3")
                            {
                                <input type="submit" value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            }
                            @if (rol == "1")
                            {
                                <input type="submit" value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            }
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>