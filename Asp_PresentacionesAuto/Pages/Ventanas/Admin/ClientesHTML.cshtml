@*Pages/Ventanas/Admin/Clientes_Razor.cshtml*@
@page
@model Asp_PresentacionesAuto.Pages.Ventanas.Admin.ClientesHTMLModel;
@{
    ViewData["Title"] = "Clientes";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Clientes</h3>
            </div>
            
            <div>
                <a href="/Ventanas/Admin/IndexAdmin"
                   class="btn btn-danger">&#8592; Regresar</a>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Cliente!= null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Cliente == null)" />
            </div>

            @if (Model.Cliente != null)
            {
                <input type="hidden"
                       asp-for="@Model.Cliente!.Id" />

                <div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <div class="col-6">
                            <input id="inNombre"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Cliente!.Nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Apellido</label>
                        <div class="col-6">
                            <input id="inApellido"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Cliente!.Apellido" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Cedula</label>
                        <div class="col-6">
                            <input id="inCedula"
                                   class="cts_forms form-control"
                                   asp-for="@Model.Cliente!.Cedula" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Edad</label>
                    <div class="col-6">
                        <input id="inEdad"
                               class="cts_forms form-control"
                               asp-for="@Model.Cliente!.Edad" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Correo</label>
                    <div class="col-6">
                        <input id="inCorreo"
                               class="cts_forms form-control"
                               asp-for="@Model.Cliente!.Correo" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Telefono</label>
                    <div class="col-6">
                        <input id="inTelefono"
                               class="cts_forms form-control"
                               asp-for="@Model.Cliente!.Telefono" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Licencia de Conducción</label>
                    <input type="checkbox" asp-for="@Model.Cliente!.LicenciaConduccion" />
                </div>
                <div class="form-group">
                    <label>Puntos de Fidelidad</label>
                    <div class="col-6">
                        <input id="inPuntosFidelidad"
                               class="cts_forms form-control"
                               asp-for="@Model.Cliente!.PuntosFidelidad" />
                    </div>
                </div>
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("/Pages/Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.Cliente != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">Desea borrar el Cliente?</h6>
                            <h6 align="left">@Model.Cliente!.Nombre</h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Cedula</th>
                        <th>Edad</th>
                        <th>Correo</th>
                        <th>Telefono</th>
                        <th>LicenciasConduccion</th>
                        <th>PuntosFidelidad</th>
                    </tr>
                
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Nombre</td>
                            <td>@elemento.Apellido</td>
                            <td>@elemento.Cedula</td>
                            <td>@elemento.Correo</td>
                            <td>@elemento.Telefono</td>
                            <td>@elemento.LicenciaConduccion</td>
                            <td>@elemento.PuntosFidelidad</td>
                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>