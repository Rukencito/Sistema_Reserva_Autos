@*Pages/Ventanas/Admin/DetallesFactura_Razor.cshtml*@
@page
@model Asp_PresentacionesAuto.Pages.Ventanas.Admin.DetallesFacturaHTMLModel;
@{
    ViewData["Title"] = "DetallesFactura";
    string urlRegresar;
    var rol = HttpContext.Session.GetString("RolId");

    if (rol == "2")
        urlRegresar = "/Ventanas/Cliente/IndexClientes";
    else if (rol == "3")
        urlRegresar = "/Ventanas/Empleado/IndexEmpleados";
    else if (rol == "4")
        urlRegresar = "/Ventanas/Dueno/IndexDuenos";
    else
        urlRegresar = "/Ventanas/Admin/IndexAdmin";
}
<center>
    <div>
        <form method="POST"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>DetallesFactura</h3>
            </div>
            
            <div>
                <a href="@urlRegresar" class="btn btn-danger">&#8592; Regresar</a>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.DetallesFactura != null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.DetallesFactura == null)" />
            </div>

            @if (Model.DetallesFactura != null)
            {
                <input type="hidden"
                       asp-for="@Model.DetallesFactura!.Id" />

                <div>
                    <div class="form-group">
                        <label>Subtotal</label>
                        <div class="col-6">
                            <input id="inSubtotal"
                                   class="cts_forms form-control"
                                   asp-for="@Model.DetallesFactura!.Subtotal" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Descripcion</label>
                        <div class="col-6">
                            <input id="inDescripcion"
                                   class="cts_forms form-control"
                                   asp-for="@Model.DetallesFactura!.Descripcion" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Tipo Factura</label>
                        <div class="col-6">
                            <input id="inTipoFactura"
                                   class="cts_forms form-control"
                                   asp-for="@Model.DetallesFactura!.TipoFactura" />
                        </div>
                    </div>
                </div>
                 <div class="form-group">
                    <label>Facturas</label>
                    <div class="col-6">
                        <select id="Ventas"
                                class="cts_forms form-control"
                                asp-for="@Model.DetallesFactura!.Facturas"
                                asp-items="@(new SelectList(Model.ObtenerFacturas(), "Id", "Total"))">
                            <option value="">Seleccione la Factura</option>
                        </select>
                    </div>
                </div>
            }
            
            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("/Pages/Emergentes/Mensajes.cshtml")
                ;
            }

            @if (Model.DetallesFactura != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">Desea borrar el DetallesFactura?</h6>
                            <h6 align="left">@Model.DetallesFactura!.Subtotal</h6>
                            
                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model != null && Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Subtotal</th>
                        <th>Descripcion</th>
                        <th>TipoFactura</th>
                        <th>Facturas</th>
                    </tr>
                
                    @foreach (var elemento in Model.Lista)
                    {
                        <tr>
                            <td>@elemento.Subtotal</td>
                            <td>@elemento.Descripcion</td>
                            <td>@elemento.TipoFactura</td>
                            <td>@elemento.Factura?.Total</td>
                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@elemento.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>