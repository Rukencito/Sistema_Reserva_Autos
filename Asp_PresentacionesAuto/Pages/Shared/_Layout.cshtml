@*
    Archivo: Pages/Shared/_Layout.cshtml
    Estilo: Editorial — crema / tinta / óxido
*@

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sistema Autos</title>

    <!-- Bootstrap (utilidades) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

    <style>

            /* ═══════════════════════════════════════════
                       TOKENS
                    ═══════════════════════════════════════════ */
            :root {
                --paper: #f5f3ee;
                --cream: #ede9e0;
                --ink: #0c0c10;
                --rust: #c94c1e;
                --rust-dim: #a03a14;
                --gold: #c8922a;
                --slate: #3a3a4a;
                --mist: #9898a8;
                --line: #d8d4cc;
                --sidebar-w: 240px;
                --topbar-h: 56px;
            }

            /* ═══════════════════════════════════════════
                       RESET BASE
                    ═══════════════════════════════════════════ */
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            html, body {
                height: 100%;
                background: var(--paper);
                color: var(--ink);
                font-family: 'DM Mono', monospace;
                font-size: 14px;
                overflow-x: hidden;
            }

            /* ═══════════════════════════════════════════
                       SIDEBAR
                    ═══════════════════════════════════════════ */
            .layout-sidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: var(--sidebar-w);
                height: 100vh;
                background: var(--ink);
                display: flex;
                flex-direction: column;
                z-index: 100;
            }

            /* — Marca — */
            .sidebar-brand {
                padding: 1.6rem 1.4rem 1.4rem;
                border-bottom: 1px solid rgba(255,255,255,0.08);
                display: flex;
                align-items: center;
                gap: 0.7rem;
                text-decoration: none;
            }

            .brand-icon {
                width: 34px;
                height: 34px;
                background: var(--rust);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                flex-shrink: 0;
            }

            .brand-text {
                font-family: 'Syne', sans-serif;
                font-weight: 800;
                font-size: 1rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--paper);
                line-height: 1;
            }

            .brand-sub {
                font-size: 0.58rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                color: var(--mist);
                display: block;
                margin-top: 0.2rem;
            }

            /* — Sección de menú — */
            .sidebar-section {
                padding: 1.2rem 0 0;
            }

            .sidebar-section-label {
                font-size: 0.58rem;
                letter-spacing: 4px;
                text-transform: uppercase;
                color: var(--mist);
                padding: 0 1.4rem 0.6rem;
                display: block;
            }

            /* — Ítem de menú — */
            .sidebar-nav {
                list-style: none;
            }

                .sidebar-nav li a {
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    padding: 0.7rem 1.4rem;
                    text-decoration: none;
                    color: rgba(245,243,238,0.65);
                    font-size: 0.78rem;
                    letter-spacing: 0.5px;
                    transition: color 0.15s, background 0.15s, padding-left 0.2s;
                    border-left: 2px solid transparent;
                }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        color: var(--paper);
                        background: rgba(255,255,255,0.05);
                        border-left-color: var(--rust);
                        padding-left: 1.7rem;
                    }

                    .sidebar-nav li a .nav-icon {
                        font-size: 0.95rem;
                        flex-shrink: 0;
                        opacity: 0.8;
                    }

                    .sidebar-nav li a:hover .nav-icon,
                    .sidebar-nav li a.active .nav-icon {
                        opacity: 1;
                    }

            /* — Divisor — */
            .sidebar-divider {
                margin: 0.8rem 1.4rem;
                border: none;
                border-top: 1px solid rgba(255,255,255,0.07);
            }

            /* — Botón Admin (al fondo) — */
            .sidebar-admin {
                margin-top: auto;
                padding: 1rem 1.2rem 1.4rem;
                border-top: 1px solid rgba(255,255,255,0.08);
            }

            .btn-admin {
                display: flex;
                align-items: center;
                gap: 0.7rem;
                width: 100%;
                padding: 0.75rem 1rem;
                background: var(--rust);
                color: var(--paper);
                border: none;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.72rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                text-decoration: none;
                cursor: pointer;
                transition: background 0.2s, padding-left 0.2s;
            }

                .btn-admin:hover {
                    background: var(--rust-dim);
                    color: var(--paper);
                    text-decoration: none;
                    padding-left: 1.3rem;
                }

                .btn-admin .admin-arrow {
                    margin-left: auto;
                    font-size: 0.8rem;
                    transition: transform 0.2s;
                }

                .btn-admin:hover .admin-arrow {
                    transform: translateX(3px);
                }

            /* ═══════════════════════════════════════════
                       TOPBAR
                    ═══════════════════════════════════════════ */
            .layout-topbar {
                position: fixed;
                top: 0;
                left: var(--sidebar-w);
                right: 0;
                height: var(--topbar-h);
                background: var(--paper);
                border-bottom: 2px solid var(--ink);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 2rem;
                z-index: 90;
            }

            .topbar-title {
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.78rem;
                letter-spacing: 4px;
                text-transform: uppercase;
                color: var(--slate);
            }

                .topbar-title em {
                    font-style: normal;
                    color: var(--rust);
                }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }

            .topbar-time {
                font-size: 0.65rem;
                letter-spacing: 2px;
                color: var(--mist);
            }

            .topbar-user {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                font-size: 0.72rem;
                color: var(--slate);
                letter-spacing: 1px;
            }

            .user-avatar {
                width: 28px;
                height: 28px;
                background: var(--ink);
                color: var(--paper);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
            }

            /* ═══════════════════════════════════════════
                       CONTENIDO PRINCIPAL
                    ═══════════════════════════════════════════ */
            .layout-main {
                margin-left: var(--sidebar-w);
                padding-top: var(--topbar-h);
                min-height: 100vh;
                background: var(--paper);
            }

            .layout-body {
                padding: 2rem 2.5rem 3rem;
            }

            /* ═══════════════════════════════════════════
                       HELPERS GLOBALES
                    ═══════════════════════════════════════════ */

            /* Tablas */
            .table {
                color: var(--ink);
                border-color: var(--line);
                font-size: 0.78rem;
            }

                .table thead th {
                    background: var(--ink);
                    color: var(--paper);
                    border: none;
                    font-family: 'Syne', sans-serif;
                    font-weight: 700;
                    letter-spacing: 2px;
                    font-size: 0.68rem;
                    text-transform: uppercase;
                    padding: 0.75rem 1rem;
                }

                .table tbody tr {
                    border-bottom: 1px solid var(--line);
                    transition: background 0.12s;
                }

                    .table tbody tr:hover {
                        background: var(--cream);
                    }

                .table td, .table th {
                    padding: 0.7rem 1rem;
                    vertical-align: middle;
                }

            /* Botones */
            .btn-primary {
                background: var(--rust);
                border: none;
                border-radius: 0;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.72rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 0.6rem 1.2rem;
                color: var(--paper);
                transition: background 0.2s;
            }

                .btn-primary:hover, .btn-primary:focus {
                    background: var(--rust-dim);
                    color: var(--paper);
                }

            .btn-secondary {
                background: transparent;
                border: 2px solid var(--ink);
                border-radius: 0;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.72rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 0.5rem 1.2rem;
                color: var(--ink);
                transition: background 0.2s, color 0.2s;
            }

                .btn-secondary:hover {
                    background: var(--ink);
                    color: var(--paper);
                }

            .btn-danger {
                background: transparent;
                border: 2px solid var(--rust);
                border-radius: 0;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.72rem;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 0.5rem 1.2rem;
                color: var(--rust);
                transition: background 0.2s, color 0.2s;
            }

                .btn-danger:hover {
                    background: var(--rust);
                    color: var(--paper);
                }

            /* Inputs */
            .form-control, .form-select {
                border-radius: 0;
                border: 1px solid var(--line);
                background: var(--paper);
                color: var(--ink);
                font-family: 'DM Mono', monospace;
                font-size: 0.78rem;
                padding: 0.55rem 0.9rem;
                transition: border-color 0.15s;
            }

                .form-control:focus, .form-select:focus {
                    border-color: var(--ink);
                    box-shadow: none;
                    background: var(--cream);
                    color: var(--ink);
                }

            .form-label {
                font-size: 0.65rem;
                letter-spacing: 3px;
                text-transform: uppercase;
                color: var(--mist);
                margin-bottom: 0.4rem;
                display: block;
            }

            /* Cards de contenido */
            .content-card {
                background: var(--paper);
                border: 1px solid var(--line);
                border-top: 3px solid var(--ink);
                padding: 1.5rem 2rem;
                margin-bottom: 1.5rem;
            }

            .content-card-title {
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                font-size: 0.72rem;
                letter-spacing: 4px;
                text-transform: uppercase;
                color: var(--slate);
                margin-bottom: 1.2rem;
                padding-bottom: 0.8rem;
                border-bottom: 1px solid var(--line);
            }

            /* Badges */
            .badge-status {
                display: inline-block;
                padding: 0.2rem 0.6rem;
                font-size: 0.6rem;
                font-family: 'Syne', sans-serif;
                font-weight: 700;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

            .badge-ok {
                background: #e8f5e9;
                color: #2e7d32;
                border: 1px solid #a5d6a7;
            }

            .badge-warn {
                background: #fff8e1;
                color: #f57f17;
                border: 1px solid #ffe082;
            }

            .badge-err {
                background: #fce4ec;
                color: #c62828;
                border: 1px solid #ef9a9a;
            }

            .badge-neu {
                background: var(--cream);
                color: var(--slate);
                border: 1px solid var(--line);
            }

            /* ═══════════════════════════════════════════
                       RESPONSIVE
                    ═══════════════════════════════════════════ */
            @@media (max-width: 900px) {
                :root {
                    --sidebar-w: 64px;
                }

                .brand-text, .brand-sub,
                .sidebar-section-label,
                .sidebar-nav li a span:not(.nav-icon),
                .btn-admin span:not(.admin-arrow) {
                    display: none;
                }

                .sidebar-nav li a {
                    justify-content: center;
                    padding: 0.8rem;
                    border-left: none;
                    border-bottom: 2px solid transparent;
                }

                    .sidebar-nav li a:hover,
                    .sidebar-nav li a.active {
                        padding-left: 0.8rem;
                        border-left: none;
                        border-bottom-color: var(--rust);
                    }

                .btn-admin {
                    justify-content: center;
                    padding: 0.8rem;
                }

                    .btn-admin:hover {
                        padding-left: 0.8rem;
                    }

                .brand-icon {
                    margin: 0 auto;
                }

                .sidebar-brand {
                    justify-content: center;
                }

                .admin-arrow {
                    display: none;
                }
            }

    </style>
</head>

<body>

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <aside class="layout-sidebar">

        <a class="sidebar-brand" asp-page="/Index">
            <div class="brand-icon">🚗</div>
            <div>
                <span class="brand-text">Autos</span>
                <span class="brand-sub">Sistema de Reserva</span>
            </div>
        </a>

        <div class="sidebar-section">
            <span class="sidebar-section-label">Navegación</span>
            <ul class="sidebar-nav">
                <li>
                    <a asp-page="/Index">
                        <span class="nav-icon">⌂</span>
                        <span>Inicio</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="nav-icon">🚗</span>
                        <span>Autos</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="nav-icon">🙋</span>
                        <span>Clientes</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="nav-icon">📅</span>
                        <span>Reservas</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <span class="nav-icon">💳</span>
                        <span>Pagos</span>
                    </a>
                </li>
                <li>
                    <a asp-page="/Login">
                        <span class="nav-icon">💳</span>
                        <span>Iniciar Sesion</span>
                    </a>
                </li>
            </ul>
        </div>

        <hr class="sidebar-divider" />

        <div class="sidebar-admin">
            <a asp-page="/Ventanas/Admin/IndexAdmin" class="btn-admin">
                <span>⬡</span>
                <span>Panel Admin</span>
                <span class="admin-arrow">→</span>
            </a>
        </div>

    </aside>

    <!-- ══════════════ TOPBAR ══════════════ -->
    <header class="layout-topbar">
        <span class="topbar-title">
            Sistema <em>Reserva</em> Autos
        </span>
        <div class="topbar-right">
            <span class="topbar-time" id="js-clock"></span>
            <div class="topbar-user">
                <div class="user-avatar">A</div>
                <span>Administrador</span>
            </div>
        </div>
    </header>

    <!-- ══════════════ CONTENIDO ══════════════ -->
    <main class="layout-main">
        <div class="layout-body">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function tick() {
        var el = document.getElementById('js-clock');
        if (el) {
        var d = new Date();
        el.textContent = d.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        setTimeout(tick, 1000);
        })();

        (function () {
        var links = document.querySelectorAll('.sidebar-nav a');
        links.forEach(function (a) {
        if (a.href === window.location.href) a.classList.add('active');
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
